public class Solution {
    public int StrStr(string haystack, string needle) {
        var p2 = 0;
        var matchCount = 0;

        for(var p1 = 0; p1 < haystack.Length && p2 < needle.Length; p1++, p2++){
            
            if(haystack[p1] != needle[p2]){
                p1 -= p2; 
                p2 = -1;                
                matchCount = 0;
            }
            else{
                matchCount++;

                if(matchCount == needle.Length)
                    return p1 - p2;
            }
        }

        return -1;
    }
}