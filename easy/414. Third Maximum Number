public class Solution {
    public int ThirdMax(int[] nums) {
        long first = long.MinValue, 
                     second = long.MinValue, 
                     third = long.MinValue;

        foreach (var num in nums) {
            if (num == first || num == second || num == third)
                continue; 

            if (num > first) {
                third = second;
                second = first;
                first = num;
            } else if (num > second) {
                third = second;
                second = num;
            } else if (num > third) {
                third = num;
            }
        }

        return third == long.MinValue ? (int)first : (int)third;
    }
}